# Firestore (required to run REServer)
GOOGLE_APPLICATION_CREDENTIALS=
FIRESTORE_PROJECT_ID=

# Supabase / Postgres (required only for one-time migration: FirestoreSupabaseMigrator)
SUPABASE_DB_URL=
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=

# Optional migration tuning
# MIGRATE_ROW_LIMIT=1000
# MIGRATE_TABLES=property,listing,listing_price,purchaser,purchaser_interest,post_code_search_stat,counters
# LOADER_BATCH_SIZE=500
