# Supabase -> Connect -> Session pooler (not Direct) on IPv4 networks.
# Convert the dashboard URI to JDBC:
#   postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres
# becomes:
#   SUPABASE_DB_URL=jdbc:postgresql://<pooler-host>:5432/postgres?sslmode=require
#   SUPABASE_DB_USER=postgres.<project-ref>
SUPABASE_DB_URL=jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_DB_USER=postgres.bmtnchxpdqvavmkcmksj
SUPABASE_DB_PASSWORD=your-database-password
PROPERTY_CSV_PATH=/Users/tt/Downloads/nsw_property_data.csv
